<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <staticContent>
      <!-- Remove any conflicting existing entries IIS might have, then re-add -->
      <remove fileExtension=".js" />
      <remove fileExtension=".css" />
      <remove fileExtension=".jpg" />
      <remove fileExtension=".jpeg" />
      <remove fileExtension=".png" />
      <remove fileExtension=".gif" />
      <remove fileExtension=".svg" />
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />

      <mimeMap fileExtension=".js"    mimeType="application/javascript" />
      <mimeMap fileExtension=".css"   mimeType="text/css" />
      <mimeMap fileExtension=".jpg"   mimeType="image/jpeg" />
      <mimeMap fileExtension=".jpeg"  mimeType="image/jpeg" />
      <mimeMap fileExtension=".png"   mimeType="image/png" />
      <mimeMap fileExtension=".gif"   mimeType="image/gif" />
      <mimeMap fileExtension=".svg"   mimeType="image/svg+xml" />
      <mimeMap fileExtension=".woff"  mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />

      <!-- Default for HTML/CSS/JS: always revalidate with the server so a new
           deploy is picked up immediately. Without this, browsers held the old
           index.html/style.css/main.js for up to a day and the site never
           updated (the loader markup showed unstyled and never got hidden). -->
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <!-- Drop any inherited blanket Cache-Control; caching is set per path. -->
        <remove name="Cache-Control" />
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>

    <!-- Serve index.html for bare-directory requests -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

  </system.webServer>

  <!-- Comic images are large and rarely change, so cache them for a day.
       Replace an image AND give it a new filename (or hard-refresh) to bust. -->
  <location path="images">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>

</configuration>
